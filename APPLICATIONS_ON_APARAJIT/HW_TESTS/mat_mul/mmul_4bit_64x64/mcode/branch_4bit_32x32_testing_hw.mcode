        * $r25 ($u64) $r25 0
        * $r26 ($u64) $r26 0
        * $r27 ($u64) $r27 0
        * $r28 ($u64) $r28 0
        * $r29 ($u64) $r29 0
        * $r30 ($u64) $r30 0
        * $r31 ($u64) $r31 0
        ;

kload4:
	||
        $ld ($u128) $r10  [$r1 + 16]  
        $ld ($u128) $r16 [$r0 + $r2]
        $ld ($u128) $r18 [$r2 + 16]
        $ld ($u128) $r20 [$r4 + $r2]
        + $r4 ($u64) $r4 16
        ;
kload4_a:
	||
	$ld ($u128) $r22 [$r4 + $r2]
	- $r4 ($u64) $r4 16
	;
dot4:
        ||
        $dot $accumulate $r24 ($vi4) $r11 $r16
        $dot $accumulate $r25 ($vi4) $r11 $r17
        $dot $accumulate $r26 ($vi4) $r11 $r18
        $dot $accumulate $r27 ($vi4) $r11 $r19
        $dot $accumulate $r28 ($vi4) $r11 $r20
        $dot $accumulate $r29 ($vi4) $r11 $r21
        $dot $accumulate $r30 ($vi4) $r11 $r22
        $dot $accumulate $r31 ($vi4) $r11 $r23
        ;

branchK4:
