        $dot $accumulate $r25 ($vi4) $r10 $r17
        $dot $accumulate $r26 ($vi4) $r10 $r18
        $dot $accumulate $r27 ($vi4) $r10 $r19
        $dot $accumulate $r28 ($vi4) $r10 $r20
        $dot $accumulate $r29 ($vi4) $r10 $r21
        $dot $accumulate $r30 ($vi4) $r10 $r22
        $dot $accumulate $r31 ($vi4) $r10 $r23
        ;

branchK3:
        ||
