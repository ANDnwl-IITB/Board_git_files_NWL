        $st ($u64) [$r3 +  8] $r25
        $st ($u64) [$r3 + 16] $r26
        $st ($u64) [$r3 + 24] $r27
        + $r3 ($u64) $r3 32
        ;
store3_b:
	||
        $st ($u64) [$r0 + $r3] $r28
        $st ($u64) [$r3 +  8] $r29
        $st ($u64) [$r3 + 16] $r30
        $st ($u64) [$r3 + 24] $r31
        + $r3 ($u64) $r3 32
        ;

//--------------------------------------------------------------
//  ROW 4  (r11)
//--------------------------------------------------------------
restore4:
        ||
        $ld ($u64) $r1 [$r5 + 32]   // r1 = A_tile_k0 (K-iter 0 base)
        $ld ($u64) $r2 [$r5 + 40]   // r2 = B_tile_k0
