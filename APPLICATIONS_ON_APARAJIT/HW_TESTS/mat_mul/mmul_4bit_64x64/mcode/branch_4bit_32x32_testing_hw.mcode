        $st ($u64) [$r3 +  8] $r29
        $st ($u64) [$r3 + 16] $r30
        $st ($u64) [$r3 + 24] $r31
        + $r3 ($u64) $r3 32
        ;

//--------------------------------------------------------------
//  ROW 8  (r15)
//--------------------------------------------------------------
restore8:
        ||
        $ld ($u64) $r1 [$r5 + 32]   // r1 = A_tile_k0 (K-iter 0 base)
        $ld ($u64) $r2 [$r5 + 40]   // r2 = B_tile_k0
        $set $r6  0  3               // K_ctr = 3 (4 K-iters: 3 down to 0)
        $set $r4 0 128
        ;

clear8:
        ||
        * $r24 ($u64) $r24 0
        * $r25 ($u64) $r25 0
        * $r26 ($u64) $r26 0
        * $r27 ($u64) $r27 0
        * $r28 ($u64) $r28 0
        * $r29 ($u64) $r29 0
        * $r30 ($u64) $r30 0
        * $r31 ($u64) $r31 0
        ;

kload8:
	||
        $ld ($u128) $r16 [$r0 + $r2]
        $ld ($u128) $r18 [$r2 + 16]
        $ld ($u128) $r20 [$r4 + $r2]
        + $r4 ($u64) $r4 16
        ;
kload8_a:
	||
	$ld ($u128) $r14  [$r4 + $r1]
	$ld ($u128) $r22 [$r4 + $r2]
	- $r4 ($u64) $r4 16
	;
dot8:
        ||
        $dot $accumulate $r24 ($vi4) $r15 $r16
        $dot $accumulate $r25 ($vi4) $r15 $r17
        $dot $accumulate $r26 ($vi4) $r15 $r18
        $dot $accumulate $r27 ($vi4) $r15 $r19
        $dot $accumulate $r28 ($vi4) $r15 $r20
        $dot $accumulate $r29 ($vi4) $r15 $r21
        $dot $accumulate $r30 ($vi4) $r15 $r22
        $dot $accumulate $r31 ($vi4) $r15 $r23
        ;

branchK8:
        ||
        + $r1 ($u64) $r1 32
        + $r2 ($u64) $r2 32
        ? ($u64) $r6 > --1 $goto kload8
        ;

store8_a:
        ||
        $st ($u64) [$r0 + $r3] $r24
        $st ($u64) [$r3 +  8] $r25
        $st ($u64) [$r3 + 16] $r26
        $st ($u64) [$r3 + 24] $r27
        + $r3 ($u64) $r3 32
        ;
store8_b:
	||
        $st ($u64) [$r0 + $r3] $r28
        $st ($u64) [$r3 +  8] $r29
        $st ($u64) [$r3 + 16] $r30
        $st ($u64) [$r3 + 24] $r31
        + $r3 ($u64) $r3 32
        ;

//--------------------------------------------------------------
//  branchB: advance to next N-tile.
//  Restores r1 (A ptr unchanged across N-tiles) and r2 (B ptr).
//  Advances r2 by 256 (8 cols × 32 bytes/col) to next N-tile base.
//  Saves new r2 as B_tile_k0 for next tile's row restores.
//--------------------------------------------------------------
//--------------------------------------------------------------
//  branchB: advance to next N-tile.
//--------------------------------------------------------------
branchB:
    ||
        $ld ($u64) $r1 [$r5 + 32]
        $ld ($u64) $r2 [$r5 + 40]
    ;

branchB2_math:
    ||
        + $r2 ($u64) $r2 256         // B: next N-tile (Math first)
    ;

branchB2_store:
    ||
        $st ($u64) [$r5 + 40] $r2    // Store updated value
        $ld ($u64) $r4 [$r5 + 24]
    ;

branchB2_branch:
    ||
        ? ($u64) $r4 > --1 $goto loadB
    ;

//--------------------------------------------------------------
//  branchA: advance to next M-tile.
//--------------------------------------------------------------
branchA:
    ||
        $ld ($u64) $r7 [$r5 +  0]
        $ld ($u64) $r1 [$r5 +  8]
        $set $r2  0  2096
    ;

branchA2_math:
    ||
        + $r1 ($u64) $r1 256         // A_M_tile_base += 256
        $set $r2  0  2096            // Reset B to start
    ;

branchA2_store:
    ||
        $st ($u64) [$r5 +  8] $r1    // Store all updated values safely
        $st ($u64) [$r5 + 32] $r1
        $st ($u64) [$r5 + 16] $r2
        $st ($u64) [$r5 + 40] $r2
    ;

branchA4a:
    ||
        - $r7 ($u64) $r7 1           // M_ctr--
    ;

branchA4b:
    ||
        $st ($u64) [$r5 + 0] $r7
    ;

branchA4c:
    ||
        ? ($u64) $r7 > --1 $goto loadA
    ;

//--------------------------------------------------------------
//  HALT
//--------------------------------------------------------------
halt:
    ||
        $halt
        ;
