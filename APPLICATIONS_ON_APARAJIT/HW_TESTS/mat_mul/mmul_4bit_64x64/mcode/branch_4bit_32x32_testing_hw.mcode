        * $r24 ($u64) $r24 0
        * $r25 ($u64) $r25 0
        * $r26 ($u64) $r26 0
        * $r27 ($u64) $r27 0
        * $r28 ($u64) $r28 0
        * $r29 ($u64) $r29 0
        * $r30 ($u64) $r30 0
        * $r31 ($u64) $r31 0
        ;

kload6:
	||
        $ld ($u128) $r12  [$r4 + $r1]  
        $ld ($u128) $r16 [$r0 + $r2]
        $ld ($u128) $r18 [$r2 + 16]
        $ld ($u128) $r20 [$r4 + $r2]
        + $r4 ($u64) $r4 16
        ;
kload6_a:
	||
	$ld ($u128) $r22 [$r4 + $r2]
	- $r4 ($u64) $r4 16
	;

dot6:
        ||
        $dot $accumulate $r24 ($vi4) $r13 $r16
        $dot $accumulate $r25 ($vi4) $r13 $r17
        $dot $accumulate $r26 ($vi4) $r13 $r18
        $dot $accumulate $r27 ($vi4) $r13 $r19
        $dot $accumulate $r28 ($vi4) $r13 $r20
        $dot $accumulate $r29 ($vi4) $r13 $r21
        $dot $accumulate $r30 ($vi4) $r13 $r22
        $dot $accumulate $r31 ($vi4) $r13 $r23
        ;

branchK6:
        ||
        + $r1 ($u64) $r1 32
        + $r2 ($u64) $r2 32
        ? ($u64) $r6 > --1 $goto kload6
        ;

store6_a:
        ||
        $st ($u64) [$r0 + $r3] $r24
        $st ($u64) [$r3 +  8] $r25
        $st ($u64) [$r3 + 16] $r26
        $st ($u64) [$r3 + 24] $r27
        + $r3 ($u64) $r3 32
        ;
store6_b:
	||
        $st ($u64) [$r0 + $r3] $r28
        $st ($u64) [$r3 +  8] $r29
        $st ($u64) [$r3 + 16] $r30
        $st ($u64) [$r3 + 24] $r31
        + $r3 ($u64) $r3 32
        ;
//--------------------------------------------------------------
//  ROW 7  (r14)
//--------------------------------------------------------------
restore7:
        ||
        $ld ($u64) $r1 [$r5 + 32]   // r1 = A_tile_k0 (K-iter 0 base)
        $ld ($u64) $r2 [$r5 + 40]   // r2 = B_tile_k0
        $set $r6  0  3               // K_ctr = 3 (4 K-iters: 3 down to 0)
        $set $r4 0 128
        ;

clear7:
        ||
        * $r24 ($u64) $r24 0
        * $r25 ($u64) $r25 0
        * $r26 ($u64) $r26 0
        * $r27 ($u64) $r27 0
        * $r28 ($u64) $r28 0
        * $r29 ($u64) $r29 0
        * $r30 ($u64) $r30 0
        * $r31 ($u64) $r31 0
        ;

kload7:
	||
        $ld ($u128) $r16 [$r0 + $r2]
        $ld ($u128) $r18 [$r2 + 16]
        $ld ($u128) $r20 [$r4 + $r2]
        + $r4 ($u64) $r4 16
        ;
kload7_a:
	||
	$ld ($u128) $r14  [$r4 + $r1]
	$ld ($u128) $r22 [$r4 + $r2]
	- $r4 ($u64) $r4 16
	;

dot7:
        ||
        $dot $accumulate $r24 ($vi4) $r14 $r16
        $dot $accumulate $r25 ($vi4) $r14 $r17
        $dot $accumulate $r26 ($vi4) $r14 $r18
        $dot $accumulate $r27 ($vi4) $r14 $r19
        $dot $accumulate $r28 ($vi4) $r14 $r20
        $dot $accumulate $r29 ($vi4) $r14 $r21
        $dot $accumulate $r30 ($vi4) $r14 $r22
        $dot $accumulate $r31 ($vi4) $r14 $r23
        ;

branchK7:
        ||
        + $r1 ($u64) $r1 32
        + $r2 ($u64) $r2 32
        ? ($u64) $r6 > --1 $goto kload7
        ;

store7_a:
        ||
        $st ($u64) [$r0 + $r3] $r24
        $st ($u64) [$r3 +  8] $r25
        $st ($u64) [$r3 + 16] $r26
        $st ($u64) [$r3 + 24] $r27
        + $r3 ($u64) $r3 32
        ;
store7_b:
