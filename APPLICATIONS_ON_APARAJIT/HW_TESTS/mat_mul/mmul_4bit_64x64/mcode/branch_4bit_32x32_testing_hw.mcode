init:
        ||
        $set $r1  0  8       // temp: M_ctr = 8
        $set $r2  0  2096      // temp: base_A = 48
        $set $r3  0  4144    // temp: base_B = 2096
        //$set $r5  0  0    // temp: base_C = 4144
        $set $r6  0  7       // temp: N_ctr_init = 7
        ;


init2:
        ||
        $st ($u64) [$r5 +  0] $r1   // [0]  M_ctr = 7
        $st ($u64) [$r5 + 24] $r6   // [24] N_ctr_init = 7

        ;

// Relay: assign working registers from the temps set above.
// VLIW: all reads use bundle-ENTRY values, so relay is safe.
init3:
        ||
        + $r1 ($u64) $r5 48          // r1 = base_A = 48
        + $r2 ($u64) $r5 $r2
        + $r3 ($u64) $r5 $r3
        ;

init4:
        ||
        $st ($u64) [$r5 + 16] $r2   // [16] B_N_tile_base = base_B = 2096
        $st ($u64) [$r5 +  8] $r1  
        ;

//--------------------------------------------------------------
//  M-TILE LOOP HEAD  (entered by branchA)
//  Reloads N_ctr and B_N_tile_base for the start of each M-tile row.
//--------------------------------------------------------------
loadA:
        ||
        $ld ($u64) $r2 [$r5 + 16]   // r2 = B_N_tile_base (reset to base_B)
        $set $r4  0  7 
        ;

//--------------------------------------------------------------
//  N-TILE LOOP HEAD  (entered by loadA and branchB2)
//  Saves r1 (A K0-base) and r2 (B K0-base) for row-level restore.
//--------------------------------------------------------------
loadB:
        ||
        $st ($u64) [$r5 + 32] $r1   // [32] A_tile_k0 = r1
        $st ($u64) [$r5 + 40] $r2   // [40] B_tile_k0 = r2
        $st ($u64) [$r5 + 24] $r4
        ;

//--------------------------------------------------------------
//  ROW 1  (uses r8 from r8-r11 group; A rows 0-3 of M-tile)
//--------------------------------------------------------------
restore1:
        ||
        $ld ($u64) $r1 [$r5 + 32]   // r1 = A_tile_k0 (K-iter 0 base)
        $ld ($u64) $r2 [$r5 + 40]   // r2 = B_tile_k0
        $set $r6  0  3               // K_ctr = 3 (4 K-iters: 3 down to 0)
        $set $r4 0 128
        ;

clear1:
        ||
        * $r24 ($u64) $r24 0
        * $r25 ($u64) $r25 0
        * $r26 ($u64) $r26 0
        * $r27 ($u64) $r27 0
        * $r28 ($u64) $r28 0
        * $r29 ($u64) $r29 0
        * $r30 ($u64) $r30 0
        * $r31 ($u64) $r31 0
        ;

kload1:
	||
        $ld ($u128) $r8  [$r0 + $r1]  
        $ld ($u128) $r16 [$r0 + $r2]
        $ld ($u128) $r18 [$r2 + 16]
        $ld ($u128) $r20 [$r4 + $r2]
        + $r4 ($u64) $r4 16
        ;
kload1_a:
	||
	$ld ($u128) $r22 [$r4 + $r2]
	- $r4 ($u64) $r4 16
	;
	
dot1:
        ||
        $dot $accumulate $r24 ($vi4) $r8 $r16
        $dot $accumulate $r25 ($vi4) $r8 $r17
        $dot $accumulate $r26 ($vi4) $r8 $r18
        $dot $accumulate $r27 ($vi4) $r8 $r19
        $dot $accumulate $r28 ($vi4) $r8 $r20
        $dot $accumulate $r29 ($vi4) $r8 $r21
        $dot $accumulate $r30 ($vi4) $r8 $r22
        $dot $accumulate $r31 ($vi4) $r8 $r23
        ;

branchK1:
        ||
        + $r1 ($u64) $r1 32          // r1 += 32: next K-chunk of 4 rows
        + $r2 ($u64) $r2 32          // r2 += 32: next K-chunk of 4 cols
        ? ($u64) $r6 > --1 $goto kload1
        ;

store1_a:
        ||
        $st ($u64) [$r0 + $r3] $r24
        $st ($u64) [$r3 +  8] $r25
        $st ($u64) [$r3 + 16] $r26
        $st ($u64) [$r3 + 24] $r27
        + $r3 ($u64) $r3 32
        ;
store1_b:
	||
        $st ($u64) [$r0 + $r3] $r28
        $st ($u64) [$r3 +  8] $r29
        $st ($u64) [$r3 + 16] $r30
        $st ($u64) [$r3 + 24] $r31
        + $r3 ($u64) $r3 32
        ;

//--------------------------------------------------------------
//  ROW 2  (r9)
//--------------------------------------------------------------
restore2:
        ||
        $ld ($u64) $r1 [$r5 + 32]   // r1 = A_tile_k0 (K-iter 0 base)
        $ld ($u64) $r2 [$r5 + 40]   // r2 = B_tile_k0
        $set $r6  0  3               // K_ctr = 3 (4 K-iters: 3 down to 0)
        $set $r4 0 128
        ;

clear2:
        ||
        * $r24 ($u64) $r24 0
        * $r25 ($u64) $r25 0
        * $r26 ($u64) $r26 0
        * $r27 ($u64) $r27 0
        * $r28 ($u64) $r28 0
        * $r29 ($u64) $r29 0
        * $r30 ($u64) $r30 0
        * $r31 ($u64) $r31 0
	;

kload2:
	||
        $ld ($u128) $r8  [$r0 + $r1]  
        $ld ($u128) $r16 [$r0 + $r2]
        $ld ($u128) $r18 [$r2 + 16]
        $ld ($u128) $r20 [$r4 + $r2]
        + $r4 ($u64) $r4 16
        ;
kload2_a:
	||
	$ld ($u128) $r22 [$r4 + $r2]
	- $r4 ($u64) $r4 16
	;
dot2:
        ||
        $dot $accumulate $r24 ($vi4) $r9 $r16
        $dot $accumulate $r25 ($vi4) $r9 $r17
        $dot $accumulate $r26 ($vi4) $r9 $r18
        $dot $accumulate $r27 ($vi4) $r9 $r19
        $dot $accumulate $r28 ($vi4) $r9 $r20
        $dot $accumulate $r29 ($vi4) $r9 $r21
        $dot $accumulate $r30 ($vi4) $r9 $r22
        $dot $accumulate $r31 ($vi4) $r9 $r23
        ;

branchK2:
        ||
        + $r1 ($u64) $r1 32
        + $r2 ($u64) $r2 32
        ? ($u64) $r6 > --1 $goto kload2
        ;

store2_a:
        ||
        $st ($u64) [$r0 + $r3] $r24
        $st ($u64) [$r3 +  8] $r25
        $st ($u64) [$r3 + 16] $r26
        $st ($u64) [$r3 + 24] $r27
        + $r3 ($u64) $r3 32
        ;
store2_b:
	||
        $st ($u64) [$r0 + $r3] $r28
        $st ($u64) [$r3 +  8] $r29
        $st ($u64) [$r3 + 16] $r30
        $st ($u64) [$r3 + 24] $r31
        + $r3 ($u64) $r3 32
        ;

//--------------------------------------------------------------
//  ROW 3  (r10)
//--------------------------------------------------------------
restore3:
        ||
        $ld ($u64) $r1 [$r5 + 32]   // r1 = A_tile_k0 (K-iter 0 base)
        $ld ($u64) $r2 [$r5 + 40]   // r2 = B_tile_k0
        $set $r6  0  3               // K_ctr = 3 (4 K-iters: 3 down to 0)
        $set $r4 0 128
        ;

clear3:
        ||
        * $r24 ($u64) $r24 0
        * $r25 ($u64) $r25 0
        * $r26 ($u64) $r26 0
        * $r27 ($u64) $r27 0
        * $r28 ($u64) $r28 0
        * $r29 ($u64) $r29 0
        * $r30 ($u64) $r30 0
        * $r31 ($u64) $r31 0
        ;

kload3:
	||
        $ld ($u128) $r10 [$r1 + 16]  
        $ld ($u128) $r16 [$r0 + $r2]
        $ld ($u128) $r18 [$r2 + 16]
        $ld ($u128) $r20 [$r4 + $r2]
        + $r4 ($u64) $r4 16
        ;
kload3_a:
	||
	$ld ($u128) $r22 [$r4 + $r2]
	- $r4 ($u64) $r4 16
	;

dot3:
        ||
