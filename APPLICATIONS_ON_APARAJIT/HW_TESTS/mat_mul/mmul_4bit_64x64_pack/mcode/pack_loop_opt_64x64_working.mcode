init:
        ||
        $set $r1  0  8       // temp: M_ctr = 8
        $set $r2  0  2112      // temp: base_A = 48
        $set $r3  0  4160    // temp: base_B = 2096
        //$set $r7  0  0    // temp: base_C = 4144
        $set $r6  0  7       // temp: N_ctr_init = 7
        ;


init2:
        ||
        $st ($u64) [$r7 +  0] $r1   // [0]  M_ctr = 7
        $st ($u64) [$r7 + 24] $r6   // [24] N_ctr_init = 7
	+ $r2 ($u64) $r7 $r2
        + $r3 ($u64) $r7 $r3
        + $r1 ($u64) $r7 64          // r1 = base_A = 48
        ;

init4:
        ||
        $st ($u64) [$r7 + 16] $r2   // [16] B_N_tile_base = base_B = 2096
        $st ($u64) [$r7 +  8] $r1  
        ;

//--------------------------------------------------------------
//  M-TILE LOOP HEAD  (entered by branchA)
//  Reloads N_ctr and B_N_tile_base for the start of each M-tile row.
//--------------------------------------------------------------
loadA:
        ||
        $ld ($u64) $r2 [$r7 + 16]   // r2 = B_N_tile_base (reset to base_B)
        $set $r4  0  7 
        ;

//--------------------------------------------------------------
//  N-TILE LOOP HEAD  (entered by loadA and branchB2)
//  Saves r1 (A K0-base) and r2 (B K0-base) for row-level restore.
//--------------------------------------------------------------
loadB:
        ||
        $st ($u64) [$r7 + 32] $r1   // [32] A_tile_k0 = r1
        $st ($u64) [$r7 + 40] $r2   // [40] B_tile_k0 = r2
        $st ($u64) [$r7 + 24] $r4
        ;

//--------------------------------------------------------------
//  ROW 1  (uses r8 from r8-r11 group; A rows 0-3 of M-tile)
//--------------------------------------------------------------
restore1:
        ||
        $ld ($u64) $r1 [$r7 + 32]   // r1 = A_tile_k0 (K-iter 0 base)
        $ld ($u64) $r2 [$r7 + 40]   // r2 = B_tile_k0
        $set $r6  0  3               // K_ctr = 3 (4 K-iters: 3 down to 0)
       ;
clear1:
        ||
        * $r24 ($u64) $r24 0
        * $r25 ($u64) $r25 0
        * $r26 ($u64) $r26 0
        * $r27 ($u64) $r27 0
        * $r28 ($u64) $r28 0
        * $r29 ($u64) $r29 0
        * $r30 ($u64) $r30 0
        * $r31 ($u64) $r31 0
        ;
clear1_a:
        ||
        * $r8 ($u64) $r8 0
        * $r9 ($u64) $r9 0
        * $r10 ($u64) $r10 0
        * $r11 ($u64) $r11 0
        * $r12 ($u64) $r12 0
        * $r13 ($u64) $r13 0
        * $r14 ($u64) $r14 0
        * $r15 ($u64) $r15 0
        ;

kload1:
        ||
        $ld ($u128) $r4  [$r0 + $r1]
        $ld ($u256) $r16 [$r2 + $r0]
        $ld ($u256) $r20 [ $r2 + 128]

        ;

dot1:
        ||
        $dot $accumulate $r24 ($vi4) $r4 $r16
        $dot $accumulate $r25 ($vi4) $r4 $r17
        $dot $accumulate $r26 ($vi4) $r4 $r18
        $dot $accumulate $r27 ($vi4) $r4 $r19
        $dot $accumulate $r28 ($vi4) $r4 $r20
        $dot $accumulate $r29 ($vi4) $r4 $r21
        $dot $accumulate $r30 ($vi4) $r4 $r22
        $dot $accumulate $r31 ($vi4) $r4 $r23
        ;

dot1_b:
        ||
        $dot $accumulate $r8 ($vi4) $r5 $r16
        $dot $accumulate $r9 ($vi4) $r5 $r17
        $dot $accumulate $r10 ($vi4) $r5 $r18
        $dot $accumulate $r11 ($vi4) $r5 $r19
        $dot $accumulate $r12 ($vi4) $r5 $r20
        $dot $accumulate $r13 ($vi4) $r5 $r21
        $dot $accumulate $r14 ($vi4) $r5 $r22
        $dot $accumulate $r15 ($vi4) $r5 $r23
        ;


branchK1:
        ||
        + $r1 ($u64) $r1 32          // r1 += 32: next K-chunk of 4 rows
        + $r2 ($u64) $r2 32          // r2 += 32: next K-chunk of 4 cols
        ? ($u64) $r6 > --1 $goto kload1
        ;

pack1:
        ||
        $pack 64 $r24 32 $r24
        $pack 64 $r25 32 $r26
        $pack 64 $r26 32 $r28
        $pack 64 $r27 32 $r30
        $pack 64 $r8 32 $r8
        $pack 64 $r9 32 $r10
        $pack 64 $r10 32 $r12
        $pack 64 $r11 32 $r14
        ;


store1:
        ||
        $st ($u256) [$r0 + $r3] $r24
        $st ($u256) [ $r3 + 32] $r8
        + $r3 ($u64) $r3 64
        ;
restore2:
        ||
        $ld ($u64) $r1 [$r7 + 32]   // r1 = A_tile_k0 (K-iter 0 base)
        $ld ($u64) $r2 [$r7 + 40]   // r2 = B_tile_k0
        $set $r6  0  3               // K_ctr = 3 (4 K-iters: 3 down to 0)
        ;

clear2:
        ||
        * $r24 ($u64) $r24 0
        * $r25 ($u64) $r25 0
        * $r26 ($u64) $r26 0
        * $r27 ($u64) $r27 0
        * $r28 ($u64) $r28 0
        * $r29 ($u64) $r29 0
        * $r30 ($u64) $r30 0
        * $r31 ($u64) $r31 0
        ;
clear2_a:
        ||
        * $r8 ($u64) $r8 0
        * $r9 ($u64) $r9 0
        * $r10 ($u64) $r10 0
        * $r11 ($u64) $r11 0
        * $r12 ($u64) $r12 0
        * $r13 ($u64) $r13 0
        * $r14 ($u64) $r14 0
        * $r15 ($u64) $r15 0
        ;

kload2:
        ||
        $ld ($u128) $r4  [$r1 + 16]
        $ld ($u256) $r16 [$r2 + $r0]
        $ld ($u256) $r20 [ $r2 + 128]
        ;

dot2:
        ||
        $dot $accumulate $r24 ($vi4) $r4 $r16
        $dot $accumulate $r25 ($vi4) $r4 $r17
        $dot $accumulate $r26 ($vi4) $r4 $r18
        $dot $accumulate $r27 ($vi4) $r4 $r19
        $dot $accumulate $r28 ($vi4) $r4 $r20
        $dot $accumulate $r29 ($vi4) $r4 $r21
        $dot $accumulate $r30 ($vi4) $r4 $r22
        $dot $accumulate $r31 ($vi4) $r4 $r23
        ;

dot2_b:
        ||
        $dot $accumulate $r8 ($vi4) $r5 $r16
        $dot $accumulate $r9 ($vi4) $r5 $r17
        $dot $accumulate $r10 ($vi4) $r5 $r18
        $dot $accumulate $r11 ($vi4) $r5 $r19
        $dot $accumulate $r12 ($vi4) $r5 $r20
        $dot $accumulate $r13 ($vi4) $r5 $r21
        $dot $accumulate $r14 ($vi4) $r5 $r22
        $dot $accumulate $r15 ($vi4) $r5 $r23
        ;

branchK2:
        ||
        + $r1 ($u64) $r1 32
        + $r2 ($u64) $r2 32
        ? ($u64) $r6 > --1 $goto kload2
        ;

pack2:
        ||
        $pack 64 $r24 32 $r24
        $pack 64 $r25 32 $r26
        $pack 64 $r26 32 $r28
        $pack 64 $r27 32 $r30
        $pack 64 $r8 32 $r8
        $pack 64 $r9 32 $r10
        $pack 64 $r10 32 $r12
        $pack 64 $r11 32 $r14
        ;

store2:
        ||
        $st ($u256) [$r0 + $r3] $r24
        $st ($u256) [ $r3 + 32] $r8
        + $r3 ($u64) $r3 64
        ;

restore3:
        ||
        $ld ($u64) $r1 [$r7 + 32]   // r1 = A_tile_k0 (K-iter 0 base)
        $ld ($u64) $r2 [$r7 + 40]   // r2 = B_tile_k0
        $set $r6  0  3               // K_ctr = 3 (4 K-iters: 3 down to 0)
        ;

clear3:
        ||
        * $r24 ($u64) $r24 0
        * $r25 ($u64) $r25 0
        * $r26 ($u64) $r26 0
        * $r27 ($u64) $r27 0
        * $r28 ($u64) $r28 0
        * $r29 ($u64) $r29 0
        * $r30 ($u64) $r30 0
        * $r31 ($u64) $r31 0
        ;

clear3_a:
        ||
        * $r8 ($u64) $r8 0
        * $r9 ($u64) $r9 0
        * $r10 ($u64) $r10 0
        * $r11 ($u64) $r11 0
        * $r12 ($u64) $r12 0
        * $r13 ($u64) $r13 0
        * $r14 ($u64) $r14 0
        * $r15 ($u64) $r15 0
        ;

kload3:
        ||
        $ld ($u128) $r4  [ $r1 + 128]
        $ld ($u256) $r16 [$r2 + $r0]
        $ld ($u256) $r20 [ $r2 + 128]
        ;
dot3:
        ||
        $dot $accumulate $r24 ($vi4) $r4 $r16
        $dot $accumulate $r25 ($vi4) $r4 $r17
        $dot $accumulate $r26 ($vi4) $r4 $r18
        $dot $accumulate $r27 ($vi4) $r4 $r19
        $dot $accumulate $r28 ($vi4) $r4 $r20
        $dot $accumulate $r29 ($vi4) $r4 $r21
        $dot $accumulate $r30 ($vi4) $r4 $r22
        $dot $accumulate $r31 ($vi4) $r4 $r23
        ;

dot3_b:
        ||
        $dot $accumulate $r8 ($vi4) $r5 $r16
        $dot $accumulate $r9 ($vi4) $r5 $r17
        $dot $accumulate $r10 ($vi4) $r5 $r18
        $dot $accumulate $r11 ($vi4) $r5 $r19
        $dot $accumulate $r12 ($vi4) $r5 $r20
        $dot $accumulate $r13 ($vi4) $r5 $r21
        $dot $accumulate $r14 ($vi4) $r5 $r22
        $dot $accumulate $r15 ($vi4) $r5 $r23
        ;

branchK3:
        ||
        + $r1 ($u64) $r1 32
        + $r2 ($u64) $r2 32
        ? ($u64) $r6 > --1 $goto kload3
        ;
pack3:
        ||
        $pack 64 $r24 32 $r24
        $pack 64 $r25 32 $r26
        $pack 64 $r26 32 $r28
        $pack 64 $r27 32 $r30
        $pack 64 $r8 32 $r8
        $pack 64 $r9 32 $r10
        $pack 64 $r10 32 $r12
        $pack 64 $r11 32 $r14
        ;

store3:
        ||
        $st ($u256) [$r0 + $r3] $r24
        $st ($u256) [ $r3 + 32] $r8
        + $r3 ($u64) $r3 64
        ;

restore4:
        ||
        $ld ($u64) $r1 [$r7 + 32]   // r1 = A_tile_k0 (K-iter 0 base)
        $ld ($u64) $r2 [$r7 + 40]   // r2 = B_tile_k0
        $set $r6  0  3               // K_ctr = 3 (4 K-iters: 3 down to 0)
        ;


clear4:
        ||
        * $r24 ($u64) $r24 0
        * $r25 ($u64) $r25 0
        * $r26 ($u64) $r26 0
        * $r27 ($u64) $r27 0
        * $r28 ($u64) $r28 0
        * $r29 ($u64) $r29 0
        * $r30 ($u64) $r30 0
        * $r31 ($u64) $r31 0
        ;
clear4_a:
        ||
        * $r8 ($u64) $r8 0
        * $r9 ($u64) $r9 0
        * $r10 ($u64) $r10 0
        * $r11 ($u64) $r11 0
        * $r12 ($u64) $r12 0
        * $r13 ($u64) $r13 0
        * $r14 ($u64) $r14 0
        * $r15 ($u64) $r15 0
        ;

kload4:
        ||
        $ld ($u128) $r4  [$r1 + 144 ]
        $ld ($u256) $r16 [$r2 + $r0]
        $ld ($u256) $r20 [$r2 + 128]
        ;

dot4:
        ||
        $dot $accumulate $r24 ($vi4) $r4 $r16
        $dot $accumulate $r25 ($vi4) $r4 $r17
        $dot $accumulate $r26 ($vi4) $r4 $r18
        $dot $accumulate $r27 ($vi4) $r4 $r19
        $dot $accumulate $r28 ($vi4) $r4 $r20
        $dot $accumulate $r29 ($vi4) $r4 $r21
        $dot $accumulate $r30 ($vi4) $r4 $r22
        $dot $accumulate $r31 ($vi4) $r4 $r23
        ;

dot4_b:
        ||
        $dot $accumulate $r8 ($vi4) $r5 $r16
        $dot $accumulate $r9 ($vi4) $r5 $r17
        $dot $accumulate $r10 ($vi4) $r5 $r18
        $dot $accumulate $r11 ($vi4) $r5 $r19
        $dot $accumulate $r12 ($vi4) $r5 $r20
        $dot $accumulate $r13 ($vi4) $r5 $r21
        $dot $accumulate $r14 ($vi4) $r5 $r22
        $dot $accumulate $r15 ($vi4) $r5 $r23
        ;

branchK4:
        ||
        + $r1 ($u64) $r1 32
        + $r2 ($u64) $r2 32
        ? ($u64) $r6 > --1 $goto kload4
        ;
pack4:
        ||
        $pack 64 $r24 32 $r24
        $pack 64 $r25 32 $r26
        $pack 64 $r26 32 $r28
        $pack 64 $r27 32 $r30
        $pack 64 $r8 32 $r8
        $pack 64 $r9 32 $r10
        $pack 64 $r10 32 $r12
        $pack 64 $r11 32 $r14
        ;

store4:
        ||
        $st ($u256) [$r0 + $r3] $r24
        $st ($u256) [ $r3 + 32] $r8
        + $r3 ($u64) $r3 64
        ;

load_values:
	||
	$ld ($u64) $r1 [$r7 + 32]
        $ld ($u64) $r2 [$r7 + 40]
        $ld ($u64) $r4 [$r7 + 24]
        ;



branchB2_math:
    ||
        + $r2 ($u64) $r2 256         // B: next N-tile (Math first)
    ;

branchB2_store:
    ||
        $st ($u64) [$r7 + 40] $r2    // Store updated value
        ? ($i64) $r4 > --1 $goto loadB
    ;

//--------------------------------------------------------------
//  branchA: advance to next M-tile.
//--------------------------------------------------------------
branchA:
    ||
        $ld ($u64) $r5 [$r7 +  0]
        $ld ($u64) $r1 [$r7 +  8]
        $set $r2  0  256
	$set $r8  0  2112 
    ;

branchA2_math:
    ||
        + $r1 ($u64) $r1 $r2        // A_M_tile_base += 256
    	+ $r2 ($u64) $r8 $r7
	;

branchA2_store:
    ||
        $st ($u64) [$r7 +  8] $r1    // Store all updated values safely
        $st ($u64) [$r7 + 32] $r1
        $st ($u64) [$r7 + 16] $r2
        $st ($u64) [$r7 + 40] $r2
    ;

branchA4a:
    ||
        - $r5 ($u64) $r5 1           // M_ctr--
    ;

branchA4b:
    ||
        $st ($u64) [$r7 + 0] $r5
        ? ($i64) $r5 > --1 $goto loadA
    ;

//--------------------------------------------------------------
//  HALT
//--------------------------------------------------------------
halt:
    ||
        $halt
        ;
