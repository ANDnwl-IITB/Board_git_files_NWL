setting_init:
   ||
   $set $r20 0 127        //  N/4-1
   $set $r21 0 8192       //  8*2N
   $set $r28 0 1
   $set $r26 0 7          // log2(N)-2 or Number of Stages - 2
   $set $r27 0 256        // N/2
   $set $r31 0 512         // N
   $set $r18 0 0
;

set_pop1:
  ||  
  - $r29 ($i64) $r28 1
;

set_pop:
  ||
  $set $r31 0 512        // N
;

set_pop2:
  ||
  + $r22 ($i64) $r17 0
  + $r23 ($i64) $r17 8
  + $r30 ($i64) $r20 0 
  >> $r31 ($i64) $r31 $r18
;

update_r0: 
  || 
  * $r31 ($i64) $r31 $r29
  + $r24 ($i64) $r17 16
  + $r25 ($i64) $r17 24
  >> $r27 ($i64) $r31 1
;

update_r27:
  || 
  + $r27 ($i64) $r31 $r27
;

final_r_update:
  ||
  * $r31 ($i64) $r31 16
  * $r27 ($i64) $r27 16
;

load_inp:
  ||
  $ld ($u256) $r4 [$r31 + $r22]
  $ld ($u256) $r8 [$r27 + $r22]
  $ld ($u256) $r12 [$r21 + $r22]
;

add_twid:
  ||
  + $r4 ($f64) $r4 $r8
  + $r5 ($f64) $r5 $r9
  + $r6 ($f64) $r6 $r10
  + $r7 ($f64) $r7 $r11
  - $r8 ($f64) $r4 $r8 
  - $r9 ($f64) $r5 $r9
  - $r10 ($f64) $r6 $r10
  - $r11 ($f64) $r7 $r11
;

mult_twid:
  ||
  * $r8 ($f64) $r8 $r12
  * $r1 ($f64) $r9 $r13
  * $r9 ($f64) $r8 $r13
  * $r2 ($f64) $r9 $r12
  * $r10 ($f64) $r10 $r14
  * $r3 ($f64) $r11 $r15
  * $r11 ($f64) $r10 $r15
  * $r16 ($f64) $r11 $r14
;

add_twid1:
  ||
  - $r8 ($f64) $r8 $r1
  + $r9 ($f64) $r9 $r2
  - $r10 ($f64) $r10 $r3
  + $r11 ($f64) $r11 $r16
  $st ($u256) [$r31 + $r22] $r4
;


sft_st:
  ||
  $st ($u256) [$r27 + $r22] $r8
  + $r22 ($i64) $r22 32
  + $r23 ($i64) $r23 32
//  + $r24 ($i64) $r24 32
//  + $r25 ($i64) $r25 32
  ? ($i16) $r30 >--1 $goto load_inp 
;

set_update:
   ||
   ? ($i16) $r29 >--1 $goto set_pop
;

set_twiddle:
   ||
   + $r1 ($i64) $r17 0
   $set $r22 0 8192         // 2N*8
   $set $r23 0 31           // N/16-1
   + $r19 ($i64) $r17 32
;

twiddle_update:
  ||
  $ld ($u256) $r4 [$r22 + $r1]
  $ld ($u256) $r8 [$r22 + $r19]
;

mult_twid1:
  ||
  * $r4 ($f64) $r4 $r4
  * $r5 ($f64) $r5 $r5
  * $r6 ($f64) $r6 $r6
  * $r7 ($f64) $r7 $r7
  * $r2 ($f64) $r4 $r5
  * $r3 ($f64) $r7 $r6
  * $r12 ($f64) $r8 $r9
  * $r13 ($f64) $r11 $r10
;

mult_twid2:
  ||
  * $r8 ($f64) $r8 $r8
  * $r9 ($f64) $r9 $r9  
  * $r10 ($f64) $r10 $r10
  * $r11 ($f64) $r11 $r11
;

add_sub_twid:
  ||
  - $r4 ($f64) $r4 $r5
  - $r6 ($f64) $r6 $r7
  + $r5 ($f64) $r2 $r2
  + $r7 ($f64) $r3 $r3
  - $r8 ($f64) $r8 $r9
  - $r10 ($f64) $r10 $r11
  + $r9 ($f64) $r12 $r12
  + $r11 ($f64) $r13 $r13
;

st_twiddle:
  ||
  $st ($u256) [$r22 + $r1] $r4
  $st ($u256) [$r22 + $r19] $r8
  + $r1 ($i64) $r1 64
  + $r19 ($i64) $r19 64
  ? ($i16) $r23 >--1 $goto twiddle_update
;


final_loop_update:
  ||
  >> $r20 ($i64) $r20 1
  * $r28 ($i64) $r28 2
  + $r18 ($i64) $r18 1
  ? ($i16) $r26 >--1 $goto set_pop1
;

setting_init2x2:
  ||
  + $r22 ($i64) $r17 0
  + $r26 ($i64) $r17 32
  $set $r0 0 0
  $set $r20 0 127        //  N/4-1
;

load_inp2x2:
  ||
  $ld ($u256) $r4 [$r0 + $r22]
  $ld ($u256) $r8 [$r0 + $r26]
;

buttfly2x2:
  ||
  + $r4 ($f64) $r4 $r6
  + $r5 ($f64) $r5 $r7
  - $r6 ($f64) $r4 $r6
  - $r7 ($f64) $r5 $r7
  + $r8 ($f64) $r8 $r10
  + $r9 ($f64) $r9 $r11
  - $r10 ($f64) $r8 $r10
  - $r11 ($f64) $r9 $r11
;

st_2x2:
  ||
  $st ($u256) [$r0 + $r22] $r4
  + $r22 ($i64) $r22 64
  + $r23 ($i64) $r23 64
  + $r24 ($i64) $r24 64
  + $r25 ($i64) $r25 64
;

st_2x2_2:
  ||
  $st ($u256) [$r0 + $r26] $r8
  + $r26 ($i64) $r26 64
  + $r27 ($i64) $r27 64
  + $r28 ($i64) $r28 64
  + $r29 ($i64) $r29 64
  ? ($i16) $r20 >--1 $goto load_inp2x2
;

halting:  
   ||
   $halt
;




//  looping cosume extra cycles
