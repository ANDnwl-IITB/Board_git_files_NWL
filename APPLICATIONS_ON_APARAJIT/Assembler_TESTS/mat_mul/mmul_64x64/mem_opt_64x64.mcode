init:
        ||
        $set $r1  0  8      
        $set $r2  0  2112   
        $set $r3  0  4160   
      	 $set $r5  0  0    
        $set $r6  0  7     
        ;


init2:
        ||
        + $r2 ($u64) $r5 $r2
        + $r3 ($u64) $r5 $r3
        + $r1 ($u64) $r5 64         
        ;

init4:
        ||
        $st ($u64) [$r5 + 16] $r2  
        $st ($u64) [$r5 +  8] $r1
        ;

loadA:
        ||
        $ld ($u64) $r2 [$r5 + 16]  
        $set $r4  0  7
        ;

loadB:
        ||
        $st ($u64) [$r5 + 32] $r1  
        $st ($u64) [$r5 + 40] $r2  
        $st ($u64) [$r5 + 24] $r4
        ;

