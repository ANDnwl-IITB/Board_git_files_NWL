    +            $r4    ($i64)    $r1    $r2
    -            $r5    ($i64)    $r1    $r2
    >>           $r7    ($i64)    $r1    $r2
    <<           $r8    ($i64)    $r1    $r2
    $null
    $null
    ;
halt: // pc=0x8
    || 
