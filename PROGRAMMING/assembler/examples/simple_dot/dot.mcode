get_ops :
	|| 
		$ld ($i32)  $r1  [$r0 + 0] 
		$ld ($i32)  $r2  [$r0 + 4]
		$ld ($i32)  $r3  [$r0 + 8]
	;
dot_init:
	||
	        $ld ($i64)  $r4  [$r0 + $r1 ++8]	
	        $ld ($i64)  $r5  [$r0 + $r2 ++8]	
	;
dot_loop:
	||
		$dot ($i32)  $r16 ($i8) $r4 $r5
	        $ld  ($i64)  $r4  [$r0 + $r1 ++8]	
	        $ld  ($i64)  $r5  [$r0 + $r2 ++8]	
                ? ($i32) $r3 > --1 $goto dot_loop
	;
store   :
	||
		$st  ($i32)  [$r0 + 0]   $r16
		$halt
	;


