init :
	||
		+ $r1 ($i64) $r0 1
		- $r2 ($i64) $r0 1

		+ $r3 ($i64) $r0 3
		+ $r4 ($i64) $r0 4
		+ $r5 ($i64) $r0 5
		+ $r6 ($i64) $r0 6
		+ $r7 ($i64) $r0 7
		+ $r8 ($i64) $r0 8
	;
upcast1:
	||
		$cmov  ? ($i64)  $r0  ==  $r5 $r3 // r5 set to 3
		$cmov  ? ($i64)  $r0 !=   $r6 $r4 // r6 stays  6
		$cmov  ? ($i64)  $r1 > --1   $r7 $r5 // r7 set to 5
		$cmov  ? ($i64)  $r2 < ++1   $r8 $r6 // r8 set to 6
	;
halt:
	||
		$halt
	;

