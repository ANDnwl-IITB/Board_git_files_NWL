load1: ||
	$ld ($u16) $r4 [$r0 + 0]   
	$ld ($u16) $r5 [$r0 + 2]   
	$ld ($u16) $r6 [$r0 + 4]   
	$ld ($u16) $r7 [$r0 + 6]   
	;
store1: ||
	$st ($u16) [$r0 + 8]   $r4   
	$st ($u16) [$r0 + 10]  $r5   
	$st ($u16) [$r0 + 12]  $r6   
	$st ($u16) [$r0 + 14]  $r7   
	;
load2: ||
	$ld ($u16) $r8  [$r0 + 8]   
	$ld ($u16) $r9  [$r0 + 10]   
	$ld ($u16) $r10 [$r0 + 12]   
	$ld ($u16) $r11 [$r0 + 14]   

	$ld ($u64) $r12 [$r0 + 8]
	;
