$module [free_queue_daemon]
$in ()
$out ()
$is
{
  FREE_QUEUE_LOCK := 1  $buffering 1// bits of buffering = 1. 
  $branchblock [loop]
  {
    $merge $entry buffers_not_set_loopback 
    $endmerge
