    $place[buffers_not_set_loopback]
    $endif
    $dopipeline $depth 7 $buffering 1
    $fullrate 
    $merge $entry $loopback 
    $phi NENTRIES := 			  n_NENTRIES $on   $loopback 			  ($bitcast ($uint<32>) _b0 ) $on   $entry 
    // type of target is $uint<32>
    $phi LOCK_IS_FULL := 			  ($bitcast ($uint<1>) _b1 ) $on   $entry 			  n_LOCK_IS_FULL $on   $loopback 
    // type of target is $uint<1>
    $phi queue_command := 			  FREE_QUEUE_COMMAND $on   $entry ,   $loopback 
    // type of target is $uint<40>
    $endmerge
    $volatile server_id := ( $slice queue_command 39 36 )  $buffering 1
    $volatile opcode := ( $slice queue_command 35 32 )  $buffering 1
    $volatile wdata := ( $slice queue_command 31 0 )  $buffering 1
    $volatile lock := (opcode == FQ_LOCK) $buffering 1
    $volatile unlock := (opcode == FQ_UNLOCK) $buffering 1
    $volatile push := (opcode == PUSH) $buffering 1
    $volatile pop := (opcode == POP) $buffering 1
    $volatile status := (opcode == STATUS) $buffering 1
    $volatile lock_ok := (lock & LOCK_IS_FULL) $buffering 1
    $guard (lock_ok) lock_value := FREE_QUEUE_LOCK $buffering 1// bits of buffering = 1. 
    $volatile unlock_ok := (unlock & ( ~ LOCK_IS_FULL )) $buffering 1
    $guard (unlock_ok) FREE_QUEUE_LOCK := 1  $buffering 1// bits of buffering = 1. 
    $volatile push_is_ok := (push & (NENTRIES < S_MAX_NENTRIES)) $buffering 1
    $guard (push_is_ok) FREE_QUEUE := wdata $buffering 1// bits of buffering = 32. 
    $volatile pop_is_ok := (pop & (NENTRIES > 0 )) $buffering 1
    $guard (pop_is_ok) rdata := FREE_QUEUE $buffering 1// bits of buffering = 32. 
    $volatile n_NENTRIES := ( $mux push_is_ok (NENTRIES + 1 )  ( $mux pop_is_ok (NENTRIES - 1 )  NENTRIES )  )  $buffering 1
    $volatile n_LOCK_IS_FULL := ( $mux lock_ok ($bitcast ($uint<1>) _b0 )  ( $mux unlock_ok ($bitcast ($uint<1>) _b1 )  LOCK_IS_FULL )  )  $buffering 1
    $volatile result_data := (((( $mux lock ( $mux lock_ok ($bitcast ($uint<32>) _b0 )  ($bitcast ($uint<32>) _b1 ) )   _b0  )  | ( $mux unlock ($bitcast ($uint<32>) _b0 )  _b0  ) ) | ( $mux push ( $mux push_is_ok ($bitcast ($uint<32>) _b0 )  ($bitcast ($uint<32>) 2  ) )   _b0  ) ) | (( $mux pop ( $mux pop_is_ok rdata  ($bitcast ($uint<32>) _b1 ) )   _b0  )  | ( $mux status NENTRIES  _b0  ) )) $buffering 1
    FREE_QUEUE_RESPONSE := result_data $buffering 1// bits of buffering = 32. 
    $while 1 
  }
