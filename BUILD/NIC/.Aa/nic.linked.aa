      $guard (set_buffers) S_MAX_NENTRIES := wdata $buffering 1// bits of buffering = 32. 
      $guard (~read_counter) $call accessRegister (rwbar bmask index wdata ) (rdata_other ) 
      rdata := ( $mux read_counter S_FREE_RUNNING_COUNTER  rdata_other )  $buffering 1// bits of buffering = 32. 
      $barrier
