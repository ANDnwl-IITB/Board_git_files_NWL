      $guard (set_globals) $call setGlobalSignals () () 
      $volatile resp := (($bitcast ($uint<1>) _b0 ) && rdata) $buffering 1
      AFB_NIC_RESPONSE := resp $buffering 1// bits of buffering = 33. 
