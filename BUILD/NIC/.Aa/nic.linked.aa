    $endif
    $dopipeline $depth 7 $buffering 1
    $fullrate 
    $merge $entry $loopback 
    $phi NENTRIES_0 := 			  ($bitcast ($uint<32>) _b0 ) $on   $entry 			  n_NENTRIES_0 $on   $loopback 
    // type of target is $uint<32>
    $phi NENTRIES_1 := 			  ($bitcast ($uint<32>) _b0 ) $on   $entry 			  n_NENTRIES_1 $on   $loopback 
    // type of target is $uint<32>
    $phi NENTRIES_2 := 			  ($bitcast ($uint<32>) _b0 ) $on   $entry 			  n_NENTRIES_2 $on   $loopback 
    // type of target is $uint<32>
    $phi NENTRIES_3 := 			  ($bitcast ($uint<32>) _b0 ) $on   $entry 			  n_NENTRIES_3 $on   $loopback 
    // type of target is $uint<32>
    $phi queue_command := 			  TRANSMIT_QUEUE_COMMAND $on   $entry ,   $loopback 
    // type of target is $uint<40>
    $endmerge
    $volatile server_id := ( $slice queue_command 39 36 )  $buffering 1
    $volatile opcode := ( $slice queue_command 35 32 )  $buffering 1
    $volatile wdata := ( $slice queue_command 31 0 )  $buffering 1
    $volatile push := (opcode == PUSH) $buffering 1
    $volatile pop := (opcode == POP) $buffering 1
    $volatile status := (opcode == STATUS) $buffering 1
    $volatile server_0 := (server_id == SERVER_0) $buffering 1
    $volatile server_1 := (server_id == SERVER_1) $buffering 1
    $volatile server_2 := (server_id == SERVER_2) $buffering 1
    $volatile server_3 := (server_id == SERVER_3) $buffering 1
    $volatile push_is_ok_0 := ((push & (NENTRIES_0 < S_MAX_NENTRIES)) & server_0) $buffering 1
    $guard (push_is_ok_0) Tx_QUEUE_0 := wdata $buffering 1// bits of buffering = 32. 
    $volatile push_is_ok_1 := ((push & (NENTRIES_1 < S_MAX_NENTRIES)) & server_1) $buffering 1
    $guard (push_is_ok_1) Tx_QUEUE_1 := wdata $buffering 1// bits of buffering = 32. 
    $volatile push_is_ok_2 := ((push & (NENTRIES_2 < S_MAX_NENTRIES)) & server_2) $buffering 1
    $guard (push_is_ok_2) Tx_QUEUE_2 := wdata $buffering 1// bits of buffering = 32. 
    $volatile push_is_ok_3 := ((push & (NENTRIES_3 < S_MAX_NENTRIES)) & server_3) $buffering 1
    $guard (push_is_ok_3) Tx_QUEUE_3 := wdata $buffering 1// bits of buffering = 32. 
    $volatile pop_is_ok_0 := ((pop & (NENTRIES_0 > 0 )) & server_0) $buffering 1
    $guard (pop_is_ok_0) rdata_0 := Tx_QUEUE_0 $buffering 1// bits of buffering = 32. 
    $volatile pop_is_ok_1 := ((pop & (NENTRIES_1 > 0 )) & server_1) $buffering 1
    $guard (pop_is_ok_1) rdata_1 := Tx_QUEUE_1 $buffering 1// bits of buffering = 32. 
    $volatile pop_is_ok_2 := ((pop & (NENTRIES_2 > 0 )) & server_2) $buffering 1
    $guard (pop_is_ok_2) rdata_2 := Tx_QUEUE_2 $buffering 1// bits of buffering = 32. 
    $volatile pop_is_ok_3 := ((pop & (NENTRIES_3 > 0 )) & server_3) $buffering 1
    $guard (pop_is_ok_3) rdata_3 := Tx_QUEUE_3 $buffering 1// bits of buffering = 32. 
    $volatile push_is_ok := ((push_is_ok_0 | push_is_ok_1) | (push_is_ok_2 | push_is_ok_3)) $buffering 1
    $volatile pop_is_ok := ((pop_is_ok_0 | pop_is_ok_1) | (pop_is_ok_2 | pop_is_ok_3)) $buffering 1
    $volatile n_NENTRIES_0 := ( $mux push_is_ok_0 (NENTRIES_0 + 1 )  ( $mux pop_is_ok_0 (NENTRIES_0 - 1 )  NENTRIES_0 )  )  $buffering 1
    $volatile n_NENTRIES_1 := ( $mux push_is_ok_1 (NENTRIES_1 + 1 )  ( $mux pop_is_ok_1 (NENTRIES_1 - 1 )  NENTRIES_1 )  )  $buffering 1
    $volatile n_NENTRIES_2 := ( $mux push_is_ok_2 (NENTRIES_2 + 1 )  ( $mux pop_is_ok_2 (NENTRIES_2 - 1 )  NENTRIES_2 )  )  $buffering 1
    $volatile n_NENTRIES_3 := ( $mux push_is_ok_3 (NENTRIES_3 + 1 )  ( $mux pop_is_ok_3 (NENTRIES_3 - 1 )  NENTRIES_3 )  )  $buffering 1
    $volatile NENTRIES := ((( $mux server_0 NENTRIES_0  _b0  )  | ( $mux server_1 NENTRIES_1  _b0  ) ) | (( $mux server_2 NENTRIES_2  _b0  )  | ( $mux server_3 NENTRIES_3  _b0  ) )) $buffering 1
    $volatile rdata := ((( $mux pop_is_ok_0 rdata_0  _b0  )  | ( $mux pop_is_ok_1 rdata_1  _b0  ) ) | (( $mux pop_is_ok_2 rdata_2  _b0  )  | ( $mux pop_is_ok_3 rdata_3  _b0  ) )) $buffering 1
    $volatile result_data := ((( $mux push ( $mux push_is_ok ($bitcast ($uint<32>) _b0 )  ($bitcast ($uint<32>) 2  ) )   _b0  )  | ( $mux pop ( $mux pop_is_ok rdata  ($bitcast ($uint<32>) _b1 ) )   _b0  ) ) | ( $mux status NENTRIES  _b0  ) ) $buffering 1
    TRANSMIT_QUEUE_RESPONSE := result_data $buffering 1// bits of buffering = 32. 
    $while 1 
  }
}
// Memory space 0: nic_registers 
// use of gated clocks in modules 
